<!-- SYNC JS -->
<script is:inline>
// Cursor glow
(function(){
  var cur  = document.getElementById('cur');
  var ring = document.getElementById('cur-ring');
  var tx = 0, ty = 0;
  var rx = 0, ry = 0;
  var rafId = null;
  window.addEventListener('mousemove', function(e){
    cur.style.left = e.clientX + 'px';
    cur.style.top  = e.clientY + 'px';
    tx = e.clientX; ty = e.clientY;
    if(!rafId) rafId = requestAnimationFrame(lerpRing);
  }, {passive:true});
  function lerpRing(){
    rx += (tx - rx) * 0.18;
    ry += (ty - ry) * 0.18;
    ring.style.left = rx + 'px';
    ring.style.top  = ry + 'px';
    if(Math.abs(tx - rx) > 0.5 || Math.abs(ty - ry) > 0.5){
      rafId = requestAnimationFrame(lerpRing);
    } else {
      rafId = null;
    }
  }
  window.addEventListener('mousedown', function(){ ring.style.width='22px'; ring.style.height='22px'; });
  window.addEventListener('mouseup',   function(){ ring.style.width=''; ring.style.height=''; });
})();

// Hamburger menu
(function(){
  var ham = document.getElementById('ham');
  var mob = document.getElementById('mob-nav');
  if(!ham || !mob) return;
  function toggle(){
    var open = ham.classList.toggle('open');
    ham.setAttribute('aria-expanded', open);
    mob.classList.toggle('open', open);
    mob.setAttribute('aria-hidden', !open);
    document.body.style.overflow = open ? 'hidden' : '';
  }
  ham.addEventListener('click', toggle);
  mob.querySelectorAll('a').forEach(function(a){
    a.addEventListener('click', function(){
      ham.classList.remove('open');
      ham.setAttribute('aria-expanded', 'false');
      mob.classList.remove('open');
      mob.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    });
  });
})();

// Scroll progress
var prog = document.getElementById('prog');
function onScroll(){
  var s = window.scrollY, max = document.body.scrollHeight - window.innerHeight;
  prog.style.transform = 'scaleX(' + s/(max||1) + ')';
}
window.addEventListener('scroll', onScroll, {passive:true});
onScroll();

// Reveal
(function(){
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting) e.target.classList.add('on'); });
  }, {threshold:0.08, rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.rv').forEach(function(el){ io.observe(el); });
})();

// Tabs
window.switchTab = function(idx){
  document.querySelectorAll('.tb').forEach(function(b,i){ b.classList.toggle('on', i===idx); });
  document.querySelectorAll('.tp').forEach(function(p,i){
    if(i===idx){
      p.classList.add('on');
      p.style.opacity='0'; p.style.transform='translateY(10px)';
      requestAnimationFrame(function(){
        p.style.transition='opacity .3s ease,transform .3s ease';
        p.style.opacity='1'; p.style.transform='translateY(0)';
      });
    } else {
      p.classList.remove('on'); p.style.transition=''; p.style.opacity=''; p.style.transform='';
    }
  });
};

// Feature card spotlight
document.querySelectorAll('.fc').forEach(function(card){
  card.addEventListener('mousemove', function(e){
    var r = card.getBoundingClientRect();
    card.style.setProperty('--mx', ((e.clientX-r.left)/r.width*100)+'%');
    card.style.setProperty('--my', ((e.clientY-r.top)/r.height*100)+'%');
  });
});

// Liquid Glass displacement map generator
function buildDisplacementMap(w, h, rx, border) {
  var r  = rx   || 0;
  var bd = border != null ? border : 0.07;
  var b  = Math.min(w, h) * bd * 0.5;
  var svg = [
    '<svg viewBox="0 0 ',w,' ',h,'" xmlns="http://www.w3.org/2000/svg">',
    '<defs>',
    '<linearGradient id="gx" x1="100%" y1="0%" x2="0%" y2="0%">',
    '<stop offset="0%" stop-color="#0000"/>',
    '<stop offset="100%" stop-color="red"/>',
    '</linearGradient>',
    '<linearGradient id="gy" x1="0%" y1="0%" x2="0%" y2="100%">',
    '<stop offset="0%" stop-color="#0000"/>',
    '<stop offset="100%" stop-color="blue"/>',
    '</linearGradient>',
    '</defs>',
    '<rect width="',w,'" height="',h,'" fill="black"/>',
    '<rect width="',w,'" height="',h,'" rx="',r,'" fill="url(#gx)"/>',
    '<rect width="',w,'" height="',h,'" rx="',r,'" fill="url(#gy)" style="mix-blend-mode:difference"/>',
    '<rect x="',b,'" y="',b,'" width="',w-b*2,'" height="',h-b*2,'" rx="',r,'"',
    ' fill="hsl(0 0% 50% / 0.93)" style="filter:blur(11px)"/>',
    '</svg>'
  ].join('');
  return 'data:image/svg+xml,' + encodeURIComponent(svg);
}

var navDispMap = document.getElementById('nav-disp-map');
function updateNavMap(){
  var w = window.innerWidth, h = 62;
  if(navDispMap) navDispMap.setAttribute('href', buildDisplacementMap(w, h, 0, 0.04));
}
updateNavMap();
window.addEventListener('resize', updateNavMap, {passive:true});

var cardDispMap = document.getElementById('card-disp-map');
function updateCardMap(){
  var w = 400, h = 200;
  if(cardDispMap) cardDispMap.setAttribute('href', buildDisplacementMap(w, h, 16, 0.1));
}
updateCardMap();
</script>

<!-- ASYNC FLUID -->
<script is:inline type="module">
async function initFluid(){
  try {
    var { FluidSimulation } = await import('./fluid-core.js');
    var canvas = document.getElementById('fluid');
    var sim = new FluidSimulation(canvas, {
      SIM_RESOLUTION: 128,
      DYE_RESOLUTION: 1024,
      DENSITY_DISSIPATION: 0.96,
      VELOCITY_DISSIPATION: 0.97,
      CURL: 20,
      SPLAT_RADIUS: 0.16,
      SPLAT_FORCE: 8500,
      COLOR_UPDATE_SPEED: 14,
      SHADING: true,
      TRANSPARENT: true,
      BACK_COLOR: {r:0,g:0,b:0},
    });

    function coolColor(){
      var t = Math.random();
      if(t < 0.4)  return {r:0.05+Math.random()*.15, g:0.15+Math.random()*.25, b:0.55+Math.random()*.35};
      if(t < 0.75) return {r:0.2+Math.random()*.2,   g:0.05+Math.random()*.1,  b:0.45+Math.random()*.35};
                   return {r:0.0+Math.random()*.08,   g:0.35+Math.random()*.35, b:0.55+Math.random()*.35};
    }
    [[0.18,0.55,900,-500],[0.5,0.42,-700,600],[0.72,0.80,500,350],
     [0.35,0.28,-500,-700],[0.62,0.52,400,800],[0.14,0.72,800,-300]
    ].forEach(function(s,i){
      setTimeout(function(){
        sim.splat(s[0],s[1],s[2],s[3], coolColor());
      }, i * 180);
    });

    var lx = -1, ly = -1;
    window.addEventListener('mousemove', function(e){
      var nx = e.clientX / window.innerWidth;
      var ny = 1 - e.clientY / window.innerHeight;
      if(lx >= 0){
        var dx = nx - lx, dy = ny - ly;
        var spd = Math.sqrt(dx*dx + dy*dy);
        if(spd > 0.0005){
          var c = {r:Math.random()*.6+.2, g:Math.random()*.5+.15, b:Math.random()*.65+.25};
          sim.splat(nx, ny, dx * 14000, dy * 14000, c);
        }
      }
      lx = nx; ly = ny;
    }, {passive:true});

    window.addEventListener('mousedown', function(e){
      var nx = e.clientX / window.innerWidth;
      var ny = 1 - e.clientY / window.innerHeight;
      for(var i=0;i<4;i++){
        (function(ii){
          setTimeout(function(){
            var a = (ii/4)*Math.PI*2;
            var c = {r:Math.random()*.7+.3,g:Math.random()*.6+.2,b:Math.random()*.7+.3};
            sim.splat(nx,ny,Math.cos(a)*9000,Math.sin(a)*9000,c);
          }, ii*40);
        })(i);
      }
    }, {passive:true});

  } catch(e){
    var c = document.getElementById('fluid');
    if(c) c.style.display='none';
  }
}
initFluid();
</script>

